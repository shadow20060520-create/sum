/* 登录页面样式 - Glassmorphism 极简设计 */

/* 引入设计令牌 */
@import '../../styles/tokens.wxss';

/* 页面容器 - 浅灰蓝背景 */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 64rpx 48rpx;
  box-sizing: border-box;
}

/* 品牌区域 */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 64rpx;
}

.brand-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  margin-bottom: 32rpx;
  box-shadow: 
    0 8rpx 32rpx rgba(59, 130, 246, 0.3),
    0 0 0 8rpx rgba(59, 130, 246, 0.1);
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.brand-subtitle {
  font-size: 28rpx;
  color: #64748b;
  letter-spacing: 8rpx;
}

/* 登录卡片 - Glassmorphism 效果 */
.login-card {
  width: 600rpx;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 
    0 0 12rpx rgba(0, 0, 0, 0.03),
    0 16rpx 48rpx rgba(0, 0, 0, 0.08);
}

/* 卡片头部 */
.card-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.card-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
  margin-bottom: 12rpx;
}

.card-subtitle {
  font-size: 28rpx;
  color: #64748b;
}

/* 输入框组 */
.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
  margin-bottom: 12rpx;
  margin-left: 8rpx;
}

.input-field {
  width: 100%;
  height: 88rpx;
  background: rgba(241, 245, 249, 0.6);
  border-radius: 16rpx;
  padding: 0 28rpx;
  font-size: 32rpx;
  color: #1e293b;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

/* 输入框焦点状态 */
.input-field:focus {
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(59, 130, 246, 0.3);
  box-shadow: 0 0 0 4rpx rgba(59, 130, 246, 0.1);
}

/* 占位符样式 */
.input-placeholder {
  font-size: 30rpx;
  color: #94a3b8;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 48rpx;
  margin-bottom: 32rpx;
  border: none;
  box-shadow: 
    0 8rpx 24rpx rgba(59, 130, 246, 0.35),
    0 2rpx 4rpx rgba(59, 130, 246, 0.2);
  transition: all 0.15s ease;
}

/* 按钮文字 */
.login-btn text {
  font-size: 34rpx;
  font-weight: 600;
  color: white;
  letter-spacing: 8rpx;
}

/* 按钮点击物理反馈 - active:scale-95 */
.login-btn:active {
  transform: scale(0.95);
  box-shadow: 
    0 4rpx 12rpx rgba(59, 130, 246, 0.25),
    0 1rpx 2rpx rgba(59, 130, 246, 0.15);
}

/* 按钮禁用状态 */
.login-btn[disabled] {
  opacity: 0.7;
}

/* 加载状态 */
.login-btn.loading {
  background: linear-gradient(135deg, #94a3b8 0%, #cbd5e1 100%);
  box-shadow: none;
}

.btn-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: white;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 辅助链接 */
.helper-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.link-text {
  font-size: 28rpx;
  color: #64748b;
  transition: color 0.3s ease;
}

.link-text:active {
  color: #3b82f6;
}

.link-divider {
  font-size: 24rpx;
  color: #cbd5e1;
}

/* 底部版权 */
.footer {
  margin-top: auto;
  padding-top: 64rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #94a3b8;
}
