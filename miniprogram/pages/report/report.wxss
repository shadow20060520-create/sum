/* 评测详情报告页样式 - 柔和通透风格 */

/* 引入设计令牌 */
@import '../../styles/tokens.wxss';

/* 页面容器 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 50%, #f0f9ff 100%);
  padding: 32rpx;
  box-sizing: border-box;
}

/* 加载和错误状态 */
.loading-container,
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(59, 130, 246, 0.1);
  border-top-color: var(--color-primary-500);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--color-gray-600);
}

.error-text {
  font-size: 32rpx;
  color: var(--color-error-500);
  margin-bottom: 32rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  color: white;
  padding: 24rpx 64rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

/* 主内容区 */
.main-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.back-icon {
  font-size: 36rpx;
  color: var(--color-gray-700);
}

.page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-gray-900);
}

.placeholder {
  width: 72rpx;
}

/* 总分卡片 */
.score-overview-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(40rpx);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 
    0 0 12rpx rgba(0, 0, 0, 0.03),
    0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.total-score-section {
  display: flex;
  align-items: center;
  gap: 48rpx;
  margin-bottom: 48rpx;
}

.score-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

/* 分数等级样式 */
.score-circle.score-excellent {
  background: linear-gradient(135deg, #10b981 0%, #34d399 100%);
}

.score-circle.score-good {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
}

.score-circle.score-pass {
  background: linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%);
}

.score-circle.score-fail {
  background: linear-gradient(135deg, #f43f5e 0%, #fb7185 100%);
}

.score-value {
  font-size: 64rpx;
  font-weight: 700;
  color: white;
  line-height: 1;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.score-feedback {
  flex: 1;
}

.feedback-text {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.feedback-text.excellent { color: var(--color-success-500); }
.feedback-text.good { color: var(--color-primary-500); }
.feedback-text.pass { color: #f59e0b; }
.feedback-text.fail { color: var(--color-error-500); }

/* 四项分数 */
.score-details {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
  padding-top: 32rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.score-item-value {
  font-size: 40rpx;
  font-weight: 700;
}

.score-item-value.score-excellent { color: var(--color-success-500); }
.score-item-value.score-good { color: var(--color-primary-500); }
.score-item-value.score-pass { color: #f59e0b; }
.score-item-value.score-fail { color: var(--color-error-500); }

.score-item-label {
  font-size: 24rpx;
  color: var(--color-gray-500);
}

/* 卡片通用样式 */
.words-card,
.video-card,
.pitch-card {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(40rpx);
  border-radius: 32rpx;
  padding: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 
    0 0 12rpx rgba(0, 0, 0, 0.03),
    0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-gray-900);
}

.card-subtitle {
  font-size: 24rpx;
  color: var(--color-gray-500);
}

/* 图例 */
.legend {
  display: flex;
  gap: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.legend-dot.correct {
  background: var(--color-success-500);
}

.legend-dot.error {
  background: var(--color-error-500);
}

.legend-text {
  font-size: 24rpx;
  color: var(--color-gray-600);
}

/* 逐字列表 */
.words-list {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.word-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 24rpx 32rpx;
  border-radius: 20rpx;
  min-width: 100rpx;
}

.word-item.word-correct {
  background: rgba(16, 185, 129, 0.1);
}

.word-item.word-error {
  background: rgba(244, 63, 94, 0.1);
  border: 2rpx solid rgba(244, 63, 94, 0.3);
}

.word-char {
  font-size: 48rpx;
  font-family: "Kaiti SC", "STKaiti", "KaiTi", "FZKai-Z03", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 700;
  line-height: 1.18;
  text-rendering: optimizeLegibility;
}

.word-item.word-correct .word-char {
  color: var(--color-success-500);
  text-shadow: 0 8rpx 22rpx rgba(16, 185, 129, 0.14);
}

.word-item.word-error .word-char {
  color: var(--color-error-500);
  text-shadow: 0 8rpx 22rpx rgba(244, 63, 94, 0.14);
}

.word-score {
  font-size: 24rpx;
  color: var(--color-gray-500);
}

/* 视频卡片 */
.video-player-container {
  width: 100%;
  height: 400rpx;
  background: #000;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.video-player {
  width: 100%;
  height: 100%;
}

.video-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-gray-100);
}

.placeholder-text {
  font-size: 28rpx;
  color: var(--color-gray-500);
}

.video-info {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: rgba(59, 130, 246, 0.05);
  border-radius: 16rpx;
}

.video-phoneme {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.phoneme-label {
  font-size: 28rpx;
  color: var(--color-gray-600);
}

.phoneme-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-primary-500);
}

.video-description {
  font-size: 26rpx;
  color: var(--color-gray-600);
  line-height: 1.5;
}

/* 视频切换标签 */
.video-tabs {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.video-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.5);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.video-tab.active {
  background: var(--color-primary-500);
  border-color: var(--color-primary-500);
}

.tab-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-gray-700);
}

.video-tab.active .tab-text {
  color: white;
}

.tab-word {
  font-size: 22rpx;
  color: var(--color-gray-500);
  margin-top: 4rpx;
}

.video-tab.active .tab-word {
  color: rgba(255, 255, 255, 0.8);
}

/* 音高曲线占位 */
.pitch-chart-placeholder {
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  border: 2rpx dashed rgba(0, 0, 0, 0.1);
}

/* 底部操作 */
.action-area {
  display: flex;
  gap: 32rpx;
  padding: 32rpx 0;
}

.action-btn {
  flex: 1;
  padding: 28rpx 0;
  border-radius: 32rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  transition: transform 0.1s ease;
}

.action-btn:active {
  transform: scale(0.95);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.7);
  color: var(--color-gray-700);
  border: 2rpx solid rgba(0, 0, 0, 0.1);
}

.action-btn.primary {
  background: linear-gradient(135deg, #3b82f6 0%, #60a5fa 100%);
  color: white;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.3);
}
