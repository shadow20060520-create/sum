.container {
  min-height: 100vh;
  padding: 40rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
}

.header {
  margin-bottom: 40rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.task-card {
  padding: 32rpx;
  transition: transform 0.2s ease;
}

.task-card:active {
  transform: scale(0.98);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
  margin-right: 20rpx;
}

.due-date {
  background: rgba(59, 130, 246, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.due-date-text {
  font-size: 22rpx;
  color: var(--primary-color);
}

.task-desc {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

.progress-section {
  margin-top: 16rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-percent {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--primary-color);
}

.progress-bar {
  height: 8rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 4rpx;
  transition: width 0.5s ease;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: var(--text-secondary);
}
