/* 练习页面 - 跨端重构版样式 (React UI 移植) */

/* ========== 基础变量 ========== */
page {
  --color-primary: #3b82f6;
  --color-primary-light: #60a5fa;
  --color-success: #10b981;
  --color-error: #f43f5e;
  --color-bg: #f8fafc;
  --color-card: rgba(255, 255, 255, 0.6);
  --color-text: #1e293b;
  --color-text-secondary: #64748b;
  --color-text-muted: #94a3b8;
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
  --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  --radius-sm: 8rpx;
  --radius: 16rpx;
  --radius-lg: 32rpx;
  --radius-full: 9999rpx;
}

/* ========== 容器 ==========
page {
  width: 100vw;
  height: 100vh;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.container {
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, #f1f5f9 0%, #e2e8f0 100%);
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ========== 加载状态 ========== */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(59, 130, 246, 0.2);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* ========== 错误提示 ========== */
.error-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.error-text {
  font-size: 32rpx;
  color: var(--color-error);
  margin-bottom: 32rpx;
  text-align: center;
}

.retry-btn {
  background: var(--color-primary);
  color: white;
  padding: 24rpx 64rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  border: none;
}



/* ========== 顶部导航栏 (Tubelight 风格) ========== */
.navbar-wrapper {
  position: fixed;
  top: 48rpx;
  left: 0;
  width: 100vw;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 32;
  box-sizing: border-box;
}

.nav-bar {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 0 48rpx;
  margin-bottom: 32rpx;
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
  padding-top: 32rpx;
  box-sizing: border-box;
}

.nav-container {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.55);
  backdrop-filter: blur(28rpx) saturate(160%);
  padding: 12rpx;
  border-radius: var(--radius-full);
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.08);
}

.nav-item {
  position: relative;
  padding: 16rpx 40rpx;
  border-radius: var(--radius-full);
  transition: all 0.3s ease;
}

.nav-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: all 0.3s ease;
}

.nav-active .nav-text {
  color: var(--color-primary);
  font-weight: 600;
}

.nav-indicator {
  position: absolute;
  inset: 0;
  background: rgba(59, 130, 246, 0.05);
  border-radius: var(--radius-full);
  z-index: -1;
}

.indicator-light {
  position: absolute;
  top: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 64rpx;
  height: 6rpx;
  background: var(--color-primary);
  border-radius: 6rpx 6rpx 0 0;
  box-shadow: 0 0 16rpx rgba(59, 130, 246, 0.4);
}

.indicator-light::before,
.indicator-light::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
}

.indicator-light::before {
  width: 96rpx;
  height: 48rpx;
  background: rgba(59, 130, 246, 0.2);
  top: -16rpx;
  left: 50%;
  transform: translateX(-50%);
}

.indicator-light::after {
  width: 64rpx;
  height: 48rpx;
  background: rgba(59, 130, 246, 0.15);
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
}

/* ========== 核心展示区 ========== */
.content-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 48rpx;
  position: relative;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 48rpx;
}

.progress-text {
  font-size: 28rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

.demo-audio {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-full);
  transition: all 0.3s ease;
}

.demo-audio:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.8);
}

.audio-icon {
  font-size: 28rpx;
}

.audio-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

/* 成绩浮层 */
.score-float {
  position: absolute;
  top: 64rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: var(--shadow-sm);
  transition: all 0.3s ease;
}

.score-main {
  display: flex;
  align-items: baseline;
}

.score-value {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.score-unit {
  font-size: 32rpx;
  color: var(--color-primary-light);
  margin-left: 8rpx;
}

.score-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(148, 163, 184, 0.3);
}

.score-feedback {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
  line-height: 1.4;
  width: 160rpx;
}

/* 句子面板 */
.sentence-panel {
  margin-top: 160rpx;
  width: 100%;
  min-height: 200rpx;
  position: relative;
  overflow: hidden;
}

.sentence-wrapper {
  width: 100%;
  transition: all 0.3s ease;
}

.sentence-content {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx 24rpx;
  padding: 32rpx 16rpx;
}

.word {
  font-size: 72rpx;
  font-family: "Kaiti SC", "STKaiti", "KaiTi", "FZKai-Z03", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 700;
  line-height: 1.22;
  letter-spacing: 10rpx;
  transition: all 0.3s ease;
  padding: 6rpx 12rpx 10rpx;
  border-radius: var(--radius);
  text-rendering: optimizeLegibility;
}

.word-pending {
  color: var(--color-text);
  text-shadow:
    0 10rpx 28rpx rgba(59, 130, 246, 0.12),
    0 1rpx 0 rgba(255, 255, 255, 0.65);
}

.word-correct {
  color: var(--color-success);
  text-shadow: 0 10rpx 28rpx rgba(16, 185, 129, 0.16);
}

.word-error {
  color: var(--color-error);
  text-shadow: 0 10rpx 28rpx rgba(244, 63, 94, 0.14);
  cursor: pointer;
  border-bottom: 8rpx solid rgba(244, 63, 94, 0.3);
  position: relative;
}

.word-error:active {
  transform: scale(0.95);
  background: rgba(244, 63, 94, 0.05);
}

/* 提示文字 */
.hint-text {
  margin-top: 48rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* ========== 控制栏 ========== */
.control-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 64rpx;
  margin-bottom: 16rpx;
}

.control-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  transition: all 0.3s ease;
}

.control-btn.disabled {
  opacity: 0.3;
}

.control-btn:not(.disabled):active {
  transform: scale(0.95);
}

.control-btn:not(.disabled) .control-text {
  color: var(--color-primary);
}

.control-icon {
  font-size: 36rpx;
  color: var(--color-text-secondary);
}

.control-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

/* 进度点 */
.progress-dots {
  display: flex;
  gap: 12rpx;
}

.dot {
  height: 12rpx;
  border-radius: var(--radius-full);
  background: rgba(148, 163, 184, 0.4);
  transition: all 0.3s ease;
}

.dot-active {
  width: 64rpx;
  background: var(--color-primary);
}

.dot:not(.dot-active) {
  width: 12rpx;
}

/* ========== 录音区域 (液态玻璃按钮) ========== */
.record-area {
  height: 320rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 64rpx;
}

/* 容器居中，防止 flex 拉伸 */
.record-container {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

/* 呼吸波纹动画背景 */
.record-ripple {
  position: absolute;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(96, 165, 250, 0.2); /* blue-400/20 */
  border-radius: 50%;
  animation: ping 1.5s cubic-bezier(0, 0, 0.2, 1) infinite;
  z-index: 0;
}

@keyframes ping {
  75%, 100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

/* 核心录音按钮，强制正圆形 */
.record-btn {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  flex-shrink: 0; /* 绝对禁止被父级 flex 压缩或拉伸 */
  transition: transform 0.3s ease;
}

/* 按压时的回弹效果 */
.record-btn.active {
  transform: scale(0.95);
}

.record-btn:not(.active):active {
  transform: scale(1.05);
}

/* 液态玻璃背景 */
.record-btn-glass {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  box-shadow: 
    0 0 12rpx rgba(0, 0, 0, 0.03),
    0 4rpx 12rpx rgba(0, 0, 0, 0.08),
    inset 6rpx 6rpx 2rpx -6rpx rgba(0, 0, 0, 0.1),
    inset -6rpx -6rpx 2rpx -6rpx rgba(0, 0, 0, 0.08),
    inset 2rpx 2rpx 2rpx -1rpx rgba(0, 0, 0, 0.06),
    inset -2rpx -2rpx 2rpx -1rpx rgba(0, 0, 0, 0.06),
    inset 0 0 12rpx 12rpx rgba(0, 0, 0, 0.08),
    inset 0 0 4rpx 4rpx rgba(0, 0, 0, 0.04),
    0 0 24rpx rgba(255, 255, 255, 0.15);
  transition: all 0.3s ease;
}

.record-btn.active .record-btn-glass {
  background: rgba(59, 130, 246, 0.3);
}

/* 按钮图标 */
.record-btn-icon {
  position: relative;
  z-index: 10;
  font-size: 64rpx;
  transition: all 0.3s ease;
}

.record-btn.active .record-btn-icon {
  color: #1d4ed8;
}

.record-btn:not(.active) .record-btn-icon {
  color: var(--color-primary);
}

/* 录音提示 */
.record-hint {
  margin-top: 24rpx;
  font-size: 26rpx;
  color: var(--color-text-muted);
  font-weight: 500;
}

/* ========== 评测结果卡片 ========== */
.result-card {
  position: relative;
  z-index: 30; /* 确保低于底部抽屉的 z-index */
  background: #ffffff; /* 确保背景不透明，防止底部元素透出 */
  margin: 0 48rpx 320rpx;
  border-radius: var(--radius-lg);
  padding: 48rpx;
  box-shadow: var(--shadow-lg);
  animation: slideUp 0.5s ease;
  transition: opacity 0.3s ease;
}

/* 当底部抽屉打开时，降低成绩面板的透明度 */
.result-card.result-card-dimmed {
  opacity: 0.3;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.score-circle {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.score-circle .score-value {
  font-size: 80rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.score-circle .score-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
}

.score-details {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.score-item-value {
  font-size: 40rpx;
  font-weight: 600;
}

.score-item-value.correct {
  color: var(--color-success);
}

.score-item-value.error {
  color: var(--color-error);
}

.score-item-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 完成后操作按钮 */
.completed-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.action-btn.secondary {
  background: rgba(148, 163, 184, 0.2);
  color: var(--color-text-secondary);
}

.action-btn.primary {
  background: var(--color-primary);
  color: white;
}

.action-btn:active {
  transform: scale(0.95);
  opacity: 0.9;
}

/* 评测中提示 */
.evaluating-layer {
  position: fixed;
  inset: 0;
  z-index: 35;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
}

.evaluating-hint {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(20rpx);
  padding: 48rpx 64rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
}

.evaluating-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(59, 130, 246, 0.2);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.evaluating-text {
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

/* ========== 底部抽屉 (Bottom Sheet) ========== */
.sheet-overlay {
  position: fixed;
  inset: 0;
  background: rgba(30, 41, 59, 0.2);
  backdrop-filter: blur(8rpx);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  z-index: 40;
}

.sheet-overlay.overlay-visible {
  opacity: 1;
  pointer-events: auto;
}

.bottom-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  width: 100vw;
  height: 70%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(40rpx);
  border-radius: 64rpx 64rpx 0 0;
  box-shadow: 0 -20rpx 80rpx rgba(0, 0, 0, 0.1);
  transform: translateY(100%);
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  z-index: 50;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.bottom-sheet.sheet-open {
  transform: translateY(0);
}

.sheet-handle {
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 32rpx 0;
  cursor: pointer;
  box-sizing: border-box;
}

.handle-bar {
  width: 96rpx;
  height: 12rpx;
  background: rgba(148, 163, 184, 0.5);
  border-radius: var(--radius-full);
}

.sheet-content {
  flex: 1;
  padding: 0 48rpx 64rpx;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 1;
}

/* 发音区 */
.pronunciation-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 64rpx;
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 1;
}

.pronunciation-main {
  display: flex;
  align-items: flex-end;
  gap: 24rpx;
}

.pronunciation-char {
  font-size: 80rpx;
  font-family: "Kaiti SC", "STKaiti", "KaiTi", "FZKai-Z03", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.1;
}

.pronunciation-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding-bottom: 16rpx;
}

.pronunciation-pinyin {
  font-size: 40rpx;
  color: var(--color-error);
  font-weight: 500;
}

.pronunciation-tone {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.play-btn {
  width: 96rpx;
  height: 96rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.play-btn:active {
  background: rgba(59, 130, 246, 0.2);
  transform: scale(0.95);
}

.play-icon {
  font-size: 40rpx;
  color: var(--color-primary);
  margin-left: 8rpx;
}

/* 国际音标对照区 */
.ipa-section {
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(226, 232, 240, 0.85);
  border-radius: 28rpx;
  padding: 28rpx 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 40rpx;
  box-sizing: border-box;
  width: 100%;
}

.ipa-compare {
  display: flex;
  align-items: stretch;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.ipa-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.ipa-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

.ipa-value {
  font-size: 34rpx;
  color: var(--color-text);
  font-weight: 700;
  line-height: 1.2;
}

.pinyin-value {
  color: var(--color-error);
}

.ipa-divider {
  width: 1rpx;
  background: rgba(148, 163, 184, 0.28);
}

.ipa-hint {
  display: block;
  font-size: 25rpx;
  line-height: 1.55;
  color: var(--color-text-secondary);
}

/* 声调曲线区 */
.tone-curve-section {
  background: white;
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid rgba(241, 245, 249, 1);
  margin-bottom: 48rpx;
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 1;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
  display: block;
}

.curve-chart {
  height: 256rpx;
  position: relative;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 32rpx;
  border-bottom: 2rpx solid rgba(241, 245, 249, 1);
  border-left: 2rpx solid rgba(241, 245, 249, 1);
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 1;
}

.curve-canvas {
  width: 100%;
  height: 100%;
  position: absolute;
}

.curve-canvas.hidden {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 100%;
  height: 256rpx;
  opacity: 0;
}

.curve-image {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.curve-loading {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.curve-loading .loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid rgba(59, 130, 246, 0.2);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.curve-legend {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.legend-line {
  width: 48rpx;
  height: 4rpx;
}

.legend-standard {
  border-top: 4rpx dashed var(--color-text-muted);
}

.legend-user {
  background: var(--color-error);
  height: 6rpx;
}

.legend-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.diagnosis-text {
  margin-top: 24rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-error);
  font-weight: 500;
}

/* 视频区 */
.video-section {
  margin-bottom: 32rpx;
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 1;
}

.video-placeholder {
  height: 320rpx;
  background: rgba(241, 245, 249, 1);
  border-radius: var(--radius-lg);
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx solid rgba(226, 232, 240, 1);
  cursor: pointer;
  box-sizing: border-box;
  width: 100%;
  flex-shrink: 1;
}

.video-placeholder:active .video-play {
  transform: scale(0.95);
}

.video-bg {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #e2e8f0 0%, #f1f5f9 100%);
}

.video-play {
  width: 96rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
  z-index: 1;
  margin-bottom: 24rpx;
}

.video-play-icon {
  font-size: 40rpx;
  color: var(--color-primary);
  margin-left: 8rpx;
}

.video-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  z-index: 1;
}
